# OpenClaw Voice Configuration
# Copy to .env and fill in your values

# ===================
# Required: Choose ONE of these backends
# ===================

# Option A: Connect to OpenClaw Gateway (recommended)
# This gives your voice assistant full agent context, memory, and tools
OPENCLAW_GATEWAY_URL=http://localhost:18789
OPENCLAW_GATEWAY_TOKEN=your-gateway-token

# Option B: Direct OpenAI (standalone, no agent features)
# OPENAI_API_KEY=sk-your-key-here

# ===================
# Required: Text-to-Speech
# ===================

# Option A: OpenAI-compatible self-hosted TTS (for example qwen-tts)
# Set OPENCLAW_TTS_BACKEND=openai to force this path.
# The server must expose the OpenAI speech API at /audio/speech.
# OPENCLAW_TTS_BACKEND=openai
# OPENCLAW_TTS_API_BASE_URL=http://localhost:8000/v1
# OPENCLAW_TTS_API_KEY=your-local-api-key-or-placeholder
# OPENCLAW_TTS_API_MODEL=qwen-tts
# OPENCLAW_TTS_API_VOICE=Chelsie
# OPENCLAW_TTS_RESPONSE_FORMAT=pcm
# OPENCLAW_TTS_SAMPLE_RATE=24000

# Option B: ElevenLabs
ELEVENLABS_API_KEY=your-elevenlabs-key
# OPENCLAW_TTS_VOICE_ID=cgSgspJ2msm6clMCkdW9  # Optional: custom voice

# ===================
# Optional: Server settings
# ===================

OPENCLAW_HOST=0.0.0.0
OPENCLAW_PORT=8765

# STT settings
OPENCLAW_STT_MODEL=base  # tiny, base, small, medium, large-v3-turbo
OPENCLAW_STT_DEVICE=auto  # auto, cpu, cuda, mps

# Local TTS fallback if cloud / OpenAI-compatible TTS is not configured
OPENCLAW_TTS_MODEL=chatterbox  # chatterbox, xtts, mock

# Auth (set to true for production)
OPENCLAW_REQUIRE_AUTH=false
# OPENCLAW_MASTER_KEY=your-master-key  # For API key management
